@page "/{culture}/admin"
@attribute [Authorize(Roles = "administrator")]

@using MM.Shared.Models.Profile
@using MM.WEB.Modules.Profile.Core
@using Microsoft.AspNetCore.Authorization
@using MM.WEB.Modules.Auth.Core

@inherits PageCore<AdminPage>
@inject PrincipalImportApi PrincipalImportApi
@inject ProfileApi ProfileApi
@inject PrincipalApi PrincipalApi

<h3>AdminPage</h3>

@* <MudButton OnClick="ImportHandle">Import Users</MudButton> *@

<MudDataGrid T="ProfileManage" Items="@Profiles" ReadOnly="false" Filterable="true" Dense="true" FilterMode="DataGridFilterMode.ColumnFilterMenu" Class="mt-3" RowsPerPage="25">
    <Columns>
        <PropertyColumn Property="x => x.Principal.UserId" Title="UserId" />
        <PropertyColumn Property="x => x.Principal.DateTimeCreated" Title="Created" />
        <PropertyColumn Property="x => x.Profile.Country" Title="Country" />
        <PropertyColumn Property="x => x.Profile.Description" Title="Description" />
        <PropertyColumn Property="x => x.Principal.PublicProfile" Title="Public" />
        <TemplateColumn>
            <CellTemplate>
                <MudImage Src="@context.Item.Profile?.GetPhoto(ImageHelper.PhotoType.Face)" Style="width: 128px;"></MudImage>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn>
            <CellTemplate>
                <MudImage Src="@context.Item.Profile?.GetPhoto(ImageHelper.PhotoType.Body)" Style="width: 128px;"></MudImage>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn>
            <CellTemplate>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!context.Item.Principal!.PublicProfile)" OnClick="@( () => MakePrivate(context.Item) )">make private</MudButton>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="ProfileManage" />
    </PagerContent>
</MudDataGrid>

@code {
    public HashSet<ProfileManage> Profiles { get; set; } = [];

    protected override async Task LoadAuthDataAsync(CancellationToken token)
    {
        Profiles = await ProfileApi.GetAll(null, token);
    }

    private async Task MakePrivate(ProfileManage item)
    {
        try
        {
            await PrincipalApi.PrivateManage(item.Principal.UserId, cts.Token);
            item.Principal.PublicProfile = false;
        }
        catch (Exception ex)
        {
            await ProcessException(ex);
        }
    }

