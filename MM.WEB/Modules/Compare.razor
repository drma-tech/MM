<NewPageSection Title="Detailed Breakdown">
    <BodyFragment>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-2">
            Dating Apps
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Justify">
            Dating apps are designed for speed and volume. Matches are usually based on photos, short bios, and simple filters. While they provide access to many people, they often lack depth, compatibility, and clear relationship intent.
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-4 mb-2">
            Traditional Matchmaking
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Justify">
            Traditional matchmaking services rely on human experts who interview clients and manually select matches. This approach can be highly personalized, but it is expensive, slow, and limited in scale and geographic reach.
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mt-4 mb-2">
            Modern Matchmaker
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Justify">
            Modern Matchmaker combines the scalability of technology with the depth of structured compatibility data. Instead of relying on swipes or human intuition alone, it evaluates lifestyle, personality, goals, and preferences to generate meaningful matches.
        </MudText>
    </BodyFragment>
</NewPageSection>

<NewPageSection Title="Why Modern Matchmaker is Different">
    <BodyFragment>
        <div class="support-section mb-0">
            <ul>
                <li>
                    <MudText Typo="Typo.body1">
                        Data-driven compatibility instead of appearance-based matching
                    </MudText>
                </li>
                <li>
                    <MudText Typo="Typo.body1">
                        Global reach without geographic limitations
                    </MudText>
                </li>
                <li>
                    <MudText Typo="Typo.body1">
                        Transparent compatibility scoring
                    </MudText>
                </li>
                <li>
                    <MudText Typo="Typo.body1">
                        No reliance on expensive human intermediaries
                    </MudText>
                </li>
                <li>
                    <MudText Typo="Typo.body1">
                        Designed for serious relationships and real intentions
                    </MudText>
                </li>
            </ul>
        </div>
    </BodyFragment>
</NewPageSection>

@if (!AppStateStatic.IsAuthenticated)
{
    <MudPaper Elevation="2" Class="pa-4 my-12 mud-theme-primary" Style="text-align: center;">
        <MudText Typo="Typo.h6" Align="Align.Center" Class="my-3">
            See the difference for yourself and discover matches based on real compatibility.
        </MudText>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="Login" Class="my-4">
            Create Your Profile
        </MudButton>
    </MudPaper>
}

<FloatingButton Template="Template.Back"></FloatingButton>

@code {
    private async Task Login()
    {
        Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(Navigation.Uri)}");
    }
}
