@page "/compare"
@inherits PageCore<Compare>

<SeoMeta Title="Compare Dating Apps, Matchmaking & Modern Matchmaker" ForceTitle="true" Description="Compare dating apps, traditional matchmaking services, and Modern Matchmaker. Understand the differences in compatibility, cost, personalization, and results." Url="/compare" Index="true"></SeoMeta>
<NewPageSection IsPageHeader="true" Image="icon/icon-71.png" Title="Compare Dating Apps, Matchmaking & Modern Matchmaker" Description="Compare dating apps, traditional matchmaking services, and Modern Matchmaker. Understand the differences in compatibility, cost, personalization, and results." CustomBodyClass="mb-12"></NewPageSection>

<NewPageSection Title="Introduction">
    <BodyFragment>
        <MudText Typo="Typo.body1" Align="Align.Justify" Class="mb-2">
            Not all platforms for meeting people are created equal. Dating apps, traditional matchmaking services, and modern compatibility-based platforms follow very different approaches.
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Justify" Class="mb-2">
            Some prioritize speed and volume. Others focus on human curation at a high cost. Modern Matchmaker introduces a third approach: structured compatibility driven by data and user intent.
        </MudText>
        <MudText Typo="Typo.body1" Align="Align.Justify" Class="mb-2">
            Below is a direct comparison to help you understand which model fits your goals.
        </MudText>
    </BodyFragment>
</NewPageSection>

