@page "/{culture}/profile/validation/identity"
@using MM.WEB.Modules.Profile.Core
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]
@inherits PageCore<ValidationIdentity>

@inject ValidationApi ValidationApi

<HeadComponent Title="@SeoTranslations.ProfileTitle" Url=@($"/{Culture}/profile/validation/identity") Index="false"></HeadComponent>

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="@Css.Build().Small("my")">
    @GlobalTranslations.ModuleUnderDevelopment
</MudAlert>

<MudAlert Variant="Variant.Filled" Severity="Severity.Warning" Dense="true" Icon="@IconsFA.Solid.Icon("spinner").WithAnimation(IconAnimation.Spin).Font">
    Redirection in progress... Please wait.
</MudAlert>

<FloatingButton Template="Template.Back"></FloatingButton>

@code
{
    protected override async Task LoadAuthDataAsync()
    {
        if (AppStateStatic.Principal == null)
        {
            await ShowWarning("Invalid operation");
            Navigation.NavigateTo($"/{Culture}/profile");
            return;
        }

        if (!AppStateStatic.Principal.HasSparks(1))
        {
            await ShowWarning("You need at least 1 spark to validate your identity");
            return;
        }

        var email = AppStateStatic.User?.Claims.SingleOrDefault(c => c.Type == "email")?.Value;
        var url = await ValidationApi.CreateVerificationSession($"{Navigation.BaseUri}profile", email);
        Navigation.NavigateTo(url!);
    }
}