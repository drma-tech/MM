@page "/profile/validation/identity"
@using MM.WEB.Modules.Profile.Core
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]
@inherits PageCore<ValidationIdentity>

@inject ValidationApi ValidationApi

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="@Css.Build().Small("my")">
    This module is still under development. If you wish to report a bug, please contact us via the feedback button.
</MudAlert>

<FloatingButton Template="Template.Back"></FloatingButton>

@code
{
    protected override async Task LoadAuthDataAsync()
    {
        var url = await ValidationApi.CreateVerificationSession();
        Navigation.NavigateTo($"{url}?url={Navigation.BaseUri}/profile");
    }
}