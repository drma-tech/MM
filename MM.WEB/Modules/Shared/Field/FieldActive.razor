@inherits FormBase<bool>

@if (Visible)
{
    <MudGrid Spacing="@Css.SpaceSmall">
        <MudItem xs="12">
            <MudIcon Icon="@CssIcon" Color="Color.Primary" Class="me-2"></MudIcon>
            <MudText Typo="Typo.h6" Color="Color.Primary" Inline="true">
                @For.GetCustomAttribute().Name
            </MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                @For.GetCustomAttribute().Description
            </MudText>
        </MudItem>
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled" Style="width: 100%" Disabled="Disabled || Value" OnClick="@Click" Color="@(Value ? Color.Success : Color.Warning)">
                <MudIcon Icon="@(Value ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Class="me-2"></MudIcon>
                @if (Value)
                {
                    <span>@Button.Done</span>
                }
                else if (CustomButtonText.NotEmpty())
                {
                    <span>@CustomButtonText</span>
                }
                else
                {
                    <span>@Button.Pending</span>
                }
                @if (Sparks.HasValue)
                {
                    <MudChip T="string" Color="Color.Info" Label="true" Size="Size.Small" Icon="@Icons.Material.Filled.LocalFireDepartment" Style="position: absolute; right: 4px;">
                        @Sparks.Value
                    </MudChip>
                }
            </MudButton>
        </MudItem>
    </MudGrid>
    @if (For.GetCustomAttribute().WhyImportant.NotEmpty())
    {
        <MudText Typo="Typo.caption">
            @For.GetCustomAttribute().WhyImportant
        </MudText>
    }
}